{
  "functions": {
    "server.ts": {
      "runtime": "bun.sh@latest",
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/server.ts"
    }
  ]
}
